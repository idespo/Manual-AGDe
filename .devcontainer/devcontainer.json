{
    // Nombre del entorno (aparece en VS Code)
    "name": "MkDocs Manual Dev",
    
    // Imagen oficial de Material for MkDocs (ya trae Python, MkDocs, etc.)
    "image": "squidfunk/mkdocs-material",
    
    // Puerto para ver el manual en el navegador
    "forwardPorts": [8000],
    
    // Comandos que se ejecutan después de crear el contenedor
    // Se instala un plugin adicional y se configura Git para evitar errores de permisos
    "postCreateCommand": "pip install mkdocs-awesome-pages-plugin && git config --global --add safe.directory /workspaces/Manual-AGDe",
    
    // Personalizaciones para VS Code
    "customizations": {
        "vscode": {
            // Extensiones útiles para trabajar con Markdown
            "extensions": [
                "yzhang.markdown-all-in-one"
            ],
            // Configuración del editor
            "settings": {
                "files.autoSave": "afterDelay"   // Guardado automático cada pocos segundos
            }
        }
    }
}