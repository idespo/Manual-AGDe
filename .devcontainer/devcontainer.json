{
    // Nombre del entorno (solo para identificar)
    "name": "MkDocs Manual Dev",
    
    // Imagen oficial que YA tiene todo: Python, MkDocs, Material theme
    "image": "squidfunk/mkdocs-material",
    
    // Expone el puerto 8000 para ver el manual en el navegador
    "forwardPorts": [8000],
    
    // 📌 NUEVO: Instala el plugin awesome-pages después de crear el contenedor
    "postCreateCommand": "pip install mkdocs-awesome-pages-plugin",
    
    // Configuración opcional: auto-guardado y extensiones útiles
    "customizations": {
        "vscode": {
            "extensions": [
                "yzhang.markdown-all-in-one"  // Atajos y preview de Markdown
            ],
            "settings": {
                "files.autoSave": "afterDelay"  // No necesitas Ctrl+S
            }
        }
    }
}